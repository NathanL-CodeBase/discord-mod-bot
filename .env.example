# ============================================================
#  Discord Moderation Bot — Environment Variables
# ============================================================

# Your bot token from https://discord.com/developers/applications
BOT_TOKEN=your_bot_token_here

# Your Discord Application (Client) ID
CLIENT_ID=your_client_id_here

# The Guild (Server) ID where you want to use the bot
GUILD_ID=your_guild_id_here

# The channel ID where mod-log messages should be sent
LOG_CHANNEL_ID=your_log_channel_id_here

# Comma-separated list of banned words.
# - Matching is case-insensitive, so only lowercase entries are needed.
# - Spaces around commas are fine and are trimmed automatically.
BAD_WORDS=badword1, badword2, badword3

# Set to "true" to block all links, "false" to allow them
BLOCK_LINKS=false

# Max identical messages before spam detection triggers (default: 5)
SPAM_THRESHOLD=5
