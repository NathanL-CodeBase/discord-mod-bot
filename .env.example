# ============================================================
#  Discord Moderation Bot — Environment Variables
# ============================================================

# Your bot token from https://discord.com/developers/applications
BOT_TOKEN=your_bot_token_here

# Your Discord Application (Client) ID
CLIENT_ID=your_client_id_here

# ── Global Auto-Mod Defaults ─────────────────────────────────
# These apply to every server the bot is in.
# Per-server overrides are configured with /setup and stored in data/guild-configs.json.

# Comma-separated list of banned words applied globally to all servers.
# - Matching is case-insensitive, so only lowercase entries are needed.
# - Spaces around commas are fine and are trimmed automatically.
# - Server admins can add server-specific words on top of this list with /setup add-bad-words.
BAD_WORDS=badword1, badword2, badword3

# Set to "true" to block all HTTP/HTTPS links by default, "false" to allow them.
# Can be overridden per server with /setup block-links.
BLOCK_LINKS=false

# Number of messages within 5 seconds that triggers spam detection (default: 5).
# Can be overridden per server with /setup spam-threshold.
SPAM_THRESHOLD=5
